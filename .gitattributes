# Normalize line endings: LF in the repository and in every working tree,
# on all platforms. Overrides per-user core.autocrlf so prettier's default
# endOfLine ("lf") matches what is checked out.
* text=auto eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff  binary
*.woff2 binary
